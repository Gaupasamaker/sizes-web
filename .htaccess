# OpenAI access: allow user-triggered fetches and ChatGPT Search crawling
# before any future rewrite-based bot filters are evaluated.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP_USER_AGENT} (ChatGPT-User|OAI-SearchBot) [NC]
    RewriteRule ^ - [L]
</IfModule>

# Security: Protect leads.txt from public access
<Files "leads.txt">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>

# Performance: Enable basic compression and caching
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json
</IfModule>
